# Public browser configuration for the Vercel-hosted frontend.
# The browser talks to the ECS realtime backend over WSS IP while keeping API
# calls same-origin through Next.js route handlers.
NEXT_PUBLIC_COLYSEUS_URL=wss://8.148.79.214/colyseus
NEXT_PUBLIC_API_BASE_URL=/api

# Next.js server-side proxy target for backend HTTP routes.
# Vercel deployments keep this aligned with the ECS HTTPS IP entry.
# Local development can override it back to http://127.0.0.1:2567 in .env.local.
SELF_HOSTED_SERVER_BASE_URL=https://8.148.79.214
