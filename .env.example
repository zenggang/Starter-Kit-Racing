# Public browser configuration. These values are safe to expose to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase writer configuration. Use these for coordinator-approved
# room/match/result persistence paths only; never expose them through NEXT_PUBLIC_*.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only coordinator configuration. Never prefix shared secrets with NEXT_PUBLIC_*.
COORDINATOR_URL=
COORDINATOR_SHARED_SECRET=
COORDINATOR_BRIDGE_ENABLED=true
